<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mattkuo.mdreport.codegraph-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__MDREPORT_ROOT__/scripts/codegraph_sync_on_change.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__MDREPORT_ROOT__</string>

  <key>StartInterval</key>
  <integer>30</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__MDREPORT_ROOT__/logs/codegraph/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>__MDREPORT_ROOT__/logs/codegraph/launchd.err.log</string>
</dict>
</plist>
