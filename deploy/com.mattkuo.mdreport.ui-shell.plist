<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mattkuo.mdreport.ui-shell</string>

  <key>ProgramArguments</key>
  <array>
    <string>__MDREPORT_ROOT__/.venv/bin/python</string>
    <string>__MDREPORT_ROOT__/app/ui_shell.py</string>
    <string>--host</string>
    <string>0.0.0.0</string>
    <string>--port</string>
    <string>8510</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__MDREPORT_ROOT__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__MDREPORT_ROOT__/logs/ui_shell.out.log</string>

  <key>StandardErrorPath</key>
  <string>__MDREPORT_ROOT__/logs/ui_shell.err.log</string>
</dict>
</plist>
